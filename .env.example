# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (Second-Opinion Scoring)
OPENAI_API_KEY=

# Microsoft Graph / Entra ID App Registration
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
